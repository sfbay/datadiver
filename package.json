{
  "name": "datadiver-temp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && tsc --noEmit -p api/tsconfig.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:elections": "tsx scripts/build-election-archive.ts && tsx scripts/build-precinct-geojson.ts",
